<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ARCHIVE</title>

   <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Alumni+Sans+SC:ital,wght@0,100..900;1,100..900&family=Black+Ops+One&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=search" />

    <link rel="stylesheet" href="/styles/styles.css">
</head>
<body>

    
        
        <div class="navbar">
            <div class="navbar-logo">
                <a href="/">
                    <img src="/images/logoName.png" alt="Archive Logo" class="logo-name">
                </a>
                
            </div>

            <div class="navbar-options">

                <a href="/marvel">
                    <h2>MARVEL</h2>
                </a>

                <a href="/dc">
                    <h2>DC</h2>
                </a>

                <form action="/search" method="post">
                    <div class="search">
                        <span class="search-icon material-symbols-outlined">search</span>
                        
                        <input class="search-input" type="search" name="search-content" id="" placeholder="Search">
                    </div>
                </form>
            </div>

            


        </div>
    

    <img class="hero-skyline"src="/images/HeroSkyline.png" alt="Hero Skyline Image Blue" >

    <div class="search-results">

        <h1 class="search-title">
            Search Results for
            <span class="search-query">
                "<%= query %>"
            </span>
        </h1>

        <% if(results.length === 0){ %>

            <div class="no-character-container">

                <h1 class="no-character-text">

                    No Characters Found

                </h1>

            </div>

        <% } else { %>

            <div class="hero-grid">

                <% results.forEach(hero => { %>

                    <form action="<%= hero.route %>" method="post" class="hero-card <%= hero.theme %>">

                        <input
                            type="hidden"
                            name="id"
                            value="<%= hero.id %>">

                        <button type="submit">

                            <img
                                src="<%= hero.images.lg %>"
                                class="card-image"
                                alt="<%= hero.name %>">

                            <p class="hero-name">

                                <%= hero.name %>

                            </p>

                            <p class="hero-real-name">

                                <%= hero.biography.fullName %>

                            </p>

                        </button>

                    </form>

                <% }) %>

            </div>

        <% } %>

    </div>    


    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="/js/main.js" defer></script>
</body>
</html> 


